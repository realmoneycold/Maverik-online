{
  "name": "jarvis-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://127.0.0.1:5173 && set NODE_ENV=development&& electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@types/three": "^0.183.1",
    "three": "^0.183.2"
  },
  "build": {
    "appId": "com.maverik.jarvis",
    "productName": "Maverik",
    "executableName": "Maverik",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
